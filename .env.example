# ── Supabase (client-side) ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Stripe (client-side) ───────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
# Use pk_test_... for development, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Supabase Service Role (Edge Functions only — NEVER expose to the browser) ──
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# This is set as a Supabase secret, not a local .env variable.
# See Edge Functions deployment section in README.md.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Supabase JWT Secret (Edge Functions only — NEVER expose to the browser) ───
# Found in: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
# Used to verify incoming user JWTs in Edge Functions.
# Set via: supabase secrets set SUPABASE_JWT_SECRET=your_jwt_secret
# This is a Supabase-managed secret, not a local .env variable.
# SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── CORS Allowed Origin (Edge Functions only) ──────────────────────────────────
# Set to your production domain to restrict CORS in deployed Edge Functions.
# Defaults to "*" (open) when not set — safe for local development only.
# Set via: supabase secrets set ALLOWED_ORIGIN=https://yatranepal.com
# ALLOWED_ORIGIN=https://yatranepal.com
