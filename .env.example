# ── Supabase (client-side) ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Stripe (client-side) ───────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
# Use pk_test_... for development, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Supabase Service Role (Edge Functions only — NEVER expose to the browser) ──
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# This is set as a Supabase secret, not a local .env variable.
# See Edge Functions deployment section in README.md.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
